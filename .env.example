NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-public-key
SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key
DATABASE_URL=postgresql://postgres.project-ref:password@pooler-host:6543/postgres
MIGRATION_DATABASE_URL=postgresql://postgres:password@direct-host:5432/postgres

TOSS_SECRET_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_CONFIRM_URL=https://api.tosspayments.com/v1/payments/confirm
TOSS_WEBHOOK_SECRET=
PAYMENT_MOCK_MODE=true
NEXT_PUBLIC_PAYMENT_MOCK_MODE=false

# Bank transfer guide.
# If these are set in Vercel, the payment page and transfer-guide API use them.
# If missing, the app falls back to the hardcoded defaults in the payment code.
NEXT_PUBLIC_BANK_TRANSFER_BANK=
NEXT_PUBLIC_BANK_TRANSFER_ACCOUNT=
NEXT_PUBLIC_BANK_TRANSFER_HOLDER=

ADMIN_API_KEY=dev-admin-key
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

NEXT_PUBLIC_KAKAO_CHANNEL_URL=http://pf.kakao.com/_PxkzsX?from=qr
NEXT_PUBLIC_STORAGE_URL=
NEXT_PUBLIC_SITE_URL=https://builduscare.co.kr
MAX_SLOTS_PER_PERIOD=3

# Vercel Cron protection.
# If set, Vercel sends Authorization: Bearer $CRON_SECRET to cron routes.
# If missing, /api/cron/notifications returns 401 and queued notifications are not processed by cron.
CRON_SECRET=

# Notification dispatch.
# Email requires RESEND_API_KEY. SMS requires SOLAPI_*.
# Quote Kakao AlimTalk requires the approved SOLAPI Kakao channel and template values below.
# If missing, notification queue rows can be created but dispatch attempts fail with configuration errors.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Buildus Care <onboarding@resend.dev>
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=
SOLAPI_KAKAO_PFID=
SOLAPI_QUOTE_TEMPLATE_ID=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
